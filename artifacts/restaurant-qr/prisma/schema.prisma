generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLATFORM_ADMIN
  MERCHANT_OWNER
  MERCHANT_STAFF
}

enum RestaurantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_SETUP
}

enum OrderStatus {
  NEW
  PREPARING
  READY
  SERVED
  PAID
  CANCELLED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

model User {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  passwordHash String
  role         UserRole    @default(MERCHANT_OWNER)
  isActive     Boolean     @default(true)
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("users")
}

model Restaurant {
  id                  String                  @id @default(cuid())
  name                String
  slug                String                  @unique
  description         String?
  phone               String?
  address             String?
  logoUrl             String?
  currency            String                  @default("USD")
  soundEnabled        Boolean                 @default(true)
  status              RestaurantStatus        @default(PENDING_SETUP)
  onboardingCompleted Boolean                 @default(false)
  primaryColor        String?
  secondaryColor      String?
  users               User[]
  tables              Table[]
  categories          Category[]
  menuItems           MenuItem[]
  orders              Order[]
  subscription        RestaurantSubscription?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@map("restaurants")
}

model SubscriptionPlan {
  id              String                   @id @default(cuid())
  name            String
  description     String?
  price           Decimal?                 @db.Decimal(10, 2)
  displayPrice    String?
  billingInterval String                   @default("month")
  maxTables       Int                      @default(10)
  maxMenuItems    Int                      @default(50)
  maxStaffUsers   Int                      @default(3)
  featuresJson    String?
  isActive        Boolean                  @default(true)
  isPublic        Boolean                  @default(true)
  isFeatured      Boolean                  @default(false)
  sortOrder       Int                      @default(0)
  subscriptions   RestaurantSubscription[]
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@map("subscription_plans")
}

model RestaurantSubscription {
  id           String             @id @default(cuid())
  restaurantId String             @unique
  restaurant   Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  planId       String
  plan         SubscriptionPlan   @relation(fields: [planId], references: [id])
  status       SubscriptionStatus @default(TRIAL)
  startDate    DateTime           @default(now())
  endDate      DateTime?
  trialEndsAt  DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@map("restaurant_subscriptions")
}

model Lead {
  id             String   @id @default(cuid())
  name           String
  restaurantName String?
  email          String
  phone          String?
  city           String?
  message        String?
  source         String   @default("contact_form")
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@map("leads")
}

model Table {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableNumber  String
  qrToken      String     @unique @default(cuid())
  isActive     Boolean    @default(true)
  orders       Order[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, tableNumber])
  @@map("tables")
}

model Category {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  menuItems    MenuItem[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("categories")
}

model MenuItem {
  id           String      @id @default(cuid())
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categoryId   String
  category     Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name         String
  description  String?
  price        Decimal     @db.Decimal(10, 2)
  imageUrl     String?
  isAvailable  Boolean     @default(true)
  sortOrder    Int         @default(0)
  orderItems   OrderItem[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("menu_items")
}

model Order {
  id           String      @id @default(cuid())
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableId      String
  table        Table       @relation(fields: [tableId], references: [id], onDelete: Restrict)
  orderNumber  String
  status       OrderStatus @default(NEW)
  notes        String?
  subtotal     Decimal     @db.Decimal(10, 2)
  total        Decimal     @db.Decimal(10, 2)
  seenAt       DateTime?
  orderItems   OrderItem[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([restaurantId, orderNumber])
  @@map("orders")
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId   String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
  nameSnapshot String
  unitPrice    Decimal  @db.Decimal(10, 2)
  quantity     Int
  totalPrice   Decimal  @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("order_items")
}

# ============================================================
# QR Menu — Environment Variables Reference
# Copy to .env.local for development or inject via Dokploy/Docker
# ============================================================

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL="postgresql://user:password@localhost:5432/qrmenu?schema=public"

# ── NextAuth ─────────────────────────────────────────────────
# Application URL — must match deployment URL exactly
NEXTAUTH_URL="https://your-domain.com"
# Strong random secret — generate with: openssl rand -base64 64
NEXTAUTH_SECRET="change-me-in-production"

# ── Session / Customer Auth ───────────────────────────────────
# Used for customer JWT tokens (httpOnly cookie)
SESSION_SECRET="change-me-in-production"

# ── Optional: Notification Providers ─────────────────────────
# Twilio (SMS/WhatsApp)
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER="+213xxxxxxxxx"
# TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# Email (SMTP)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="noreply@your-domain.com"

# ── Optional: Storage ─────────────────────────────────────────
# S3-compatible object storage (Cloudflare R2, MinIO, AWS S3)
# STORAGE_PROVIDER="local"  # or "s3"
# S3_ENDPOINT=""
# S3_BUCKET=""
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
# S3_REGION="auto"

# ── Optional: App Config ──────────────────────────────────────
# App version for health endpoint
APP_VERSION="1.0.0"
# Upload size limit in MB
# MAX_UPLOAD_MB="5"
